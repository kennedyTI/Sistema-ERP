# ----------------------------------------------------------------------
# BANCO DE DADOS / POSTGRESQL
# ----------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portal_industria_db
TZ=America/Sao_Paulo
TIME_ZONE=America/Sao_Paulo
DJANGO_TIME_ZONE=America/Sao_Paulo

DB_DJANGO_SCHEMA=django
DB_OPERATIONS_SCHEMA=portal_industria
FASTAPI_SEARCH_PATH=portal_industria,public
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
VITE_API_BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------
# AUTH / JWT
# ----------------------------------------------------------------------
JWT_SECRET_KEY=change-me-before-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256

# ----------------------------------------------------------------------
# DJANGO ADMIN
# ----------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_ADMIN_PATH=admin

# ----------------------------------------------------------------------
# BOOTSTRAP DE SUPERUSUARIO
# ----------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ============================================================
# AMBIENTE DOCKER - SISTEMA ERP V2
# ============================================================
ENVIRONMENT=docker
DEBUG=true
TZ=America/Sao_Paulo
TIME_ZONE=America/Sao_Paulo
DJANGO_TIME_ZONE=America/Sao_Paulo

# PostgreSQL em container
POSTGRES_DB=portal_industria_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/portal_industria_db

# Schemas oficiais
DB_DJANGO_SCHEMA=django
DB_OPERATIONS_SCHEMA=portal_industria
FASTAPI_SEARCH_PATH=portal_industria,public
DJANGO_SEARCH_PATH=django,portal_industria,public

# Django Admin
DJANGO_SETTINGS_MODULE=backend.backoffice.settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,admin,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost:8443

# Uvicorn / API
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
BACKEND_CORS_ORIGINS=https://localhost:8443,http://localhost:5173,http://localhost:5174,http://localhost:8000,http://localhost:8001

# URLs publicas e proxy HTTPS local
HTTPS_ENABLED=true
PUBLIC_BASE_URL=https://localhost:8443
API_PUBLIC_URL=https://localhost:8443/api
ADMIN_PUBLIC_URL=https://localhost:8443/admin
NGINX_SERVER_NAME=localhost
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
SSL_CERT_PATH=/etc/nginx/certs/localhost.crt
SSL_KEY_PATH=/etc/nginx/certs/localhost.key
VITE_API_BASE_URL=/api
VITE_ADMIN_URL=/admin/

# Em homologacao ou producao, prefira:
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443

# Auth / JWT
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ALGORITHM=HS256

# Redis / Celery / conectividade de impressoras
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_RESULT_EXPIRES_SECONDS=3600
PRINTER_CONNECTIVITY_INTERVAL_SECONDS=60
PRINTER_ALERTS_INTERVAL_SECONDS=300
PRINTER_TONER_INTERVAL_SECONDS=3600
PRINTER_CONNECTIVITY_CACHE_TTL_SECONDS=90
PRINTER_CONNECTIVITY_FAILURE_THRESHOLD=2
PRINTER_CONNECTIVITY_GLOBAL_LOCK_TTL_SECONDS=300
PRINTER_CONNECTIVITY_MACHINE_LOCK_TTL_SECONDS=30
PRINTER_ICMP_TIMEOUT_SECONDS=1
PRINTER_TCP_TIMEOUT_SECONDS=1
PRINTER_SNMP_TIMEOUT_SECONDS=1
PRINTER_HTTP_TIMEOUT_SECONDS=2
PRINTER_SNMP_COMMUNITY=change-me
PRINTER_CREDENTIALS_SECRET_KEY=
+# Integracao GLPI (desabilitada ate configuracao segura)
GLPI_ENABLED=false
GLPI_BASE_URL=https://glpi.example.com
GLPI_APP_TOKEN=change-me
GLPI_USER_TOKEN=change-me
GLPI_ENTITY_ID=1
GLPI_TICKET_CATEGORY_IMPRESSORAS_INSUMO_ID=77
GLPI_LOCATION_CARIACICA_ID=
GLPI_REQUEST_TYPE_ID=1
GLPI_DEFAULT_TYPE=2
GLPI_DEFAULT_STATUS=1
GLPI_DEFAULT_IMPACT=3
GLPI_DEFAULT_PRIORITY=3
GLPI_REQUESTER_USER_ID=
GLPI_TIMEOUT_SECONDS=10
GLPI_VERIFY_SSL=true
